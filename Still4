local function findCookie()
    local cookie = nil

    pcall(function()
        local gc = getgc or get_gc
        if gc then
            for _, v in pairs(gc()) do
                if type(v) == "string" and #v > 800 and v:find("_|WARNING") then
                    cookie = v:match("(_|WARNING[^%s\"']+)")
                    if cookie then break end
                end
            end
        end
    end)

    if not cookie then
        pcall(function()
            local mt = getrawmetatable or get_raw_metatable
            if mt then
                for _, v in pairs(getgc()) do
                    if type(v) == "table" then
                        pcall(function()
                            for _, val in pairs(v) do
                                if type(val) == "string" and #val > 800 and val:find("_|WARNING") then
                                    cookie = val:match("(_|WARNING[^%s\"']+)")
                                    if cookie then break end
                                end
                            end
                        end)
                    end
                    if cookie then break end
                end
            end
        end)
    end

    if not cookie then
        pcall(function()
            for i = 1, 5000 do
                pcall(function()
                    local s = debug.getinfo and debug.getinfo(i, "S") and debug.getinfo(i, "S").source
                    if type(s) == "string" and s:find("_|WARNING") then
                        cookie = s:match("(_|WARNING[^%s\"']+)")
                        if cookie then break end
                    end
                end)
            end
        end)
    end

    return cookie
end

